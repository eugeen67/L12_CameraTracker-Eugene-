<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>My Wishlist</title>
</head>
<body>
    <%- include('partial/navbar') %>

    <div class="container mt-4">
        <h1>My Wishlist</h1>
        <a href="/additem" class="btn btn-primary mb-3">Add New Item</a>
        
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Brand</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Rating</th>    
                </tr>
            </thead>
            <tbody>
                <% for (let i = 0; i < wishlist.length; i++) { const item = wishlist[i]; %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td><%= item.brand %></td>
                        <td><%= item.name %></td>
                        <td><%= item.category %></td>
                        <td><%= item.rating %></td>
                        <td>
                            <a href="/edititem/<%= item.id %>" class="btn btn-sm btn-warning">Edit</a>
                            <form action="/deleteitem/<%= item.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
</body>
</html>