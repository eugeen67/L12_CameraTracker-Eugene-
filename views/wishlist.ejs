<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>My Wishlist</title>
</head>
<body>
    <%- include('partial/navbar') %>

    <div class="container mt-4">
        <h2>My Wishlist</h2>

        <% if (items.length === 0) { %>
            <p class="text-muted">Your wishlist is empty. Start adding some gear!</p>
        <% } else { %>
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Brand</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Rating</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (let i = 0; i < items.length; i++) { %>
                        <tr>
                            <td><%= i + 1 %></td>
                            <td><%= items[i].brand %></td>
                            <td><%= items[i].name %></td>
                            <td><%= items[i].category %></td>
                            <td><%= items[i].rating %></td>
                            <td>
                                <a href="/edit/<%= items[i].id %>" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form action="/delete/<%= items[i].id %>" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this item?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        <% } %>
    </div>
</body>
</html>