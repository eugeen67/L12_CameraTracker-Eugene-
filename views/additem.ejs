<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Add in Wishlist</title>
</head>
<body>
    <%- include('partial/navbar') %>

    <div class="container mt-4">
        <h1 class="mb-4">Add New Item to Wishlist</h1>
        <form action="/additem" method="POST">
            <div class="mb-3">
                <label class="form-label">Brand</label>
                <input type="text" name="brand" class="form-control" placeholder="Enter brand name" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" placeholder="Enter item name" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Category</label>
                <select name="category" class="form-select" required>
                    <option value="">Select category</option>
                    <option value="Camera">Camera</option>
                    <option value="Lens">Lens</option>
                    <option value="Others">Others</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Rating (0-5)</label>
                <input type="number" name="rating" class="form-control" min="0" max="5" step="0.1" placeholder="Enter rating" required>
            </div>
            <button type="submit" class="btn btn-primary">Add to Wishlist</button>
            <a href="/" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</body>
</html>