<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Wishlist Tracker</title>
</head>
<body>
    <%- include('partial/navbar') %>

    <div class="container mt-4">
        <h1>Photographer's Wishlist</h1>
        <p>Track all the cameras, lens & gear you wish to buy!</p>
        <hr>
        <p>You currently have: <strong><%= totalItems %></strong> item(s) in your wishlist.</p>
        <a href="/wishlist" class="btn btn-primary">View Wishlist</a>
        <a href="/additem" class="btn btn-success">Add New Item</a>
        
    </div>
</body>
</html>